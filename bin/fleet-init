#!/usr/bin/env bash
# fleet-init — register a new project with the fleet in one command.
# Seeds the docs hub if requested (INDEX + AGENTS.md + CLAUDE.md bridge from
# templates, generic coordinator skills), then writes
# ~/.config/fleet/projects/<name>.env. Worker skills are global
# (~/.claude/skills), already installed, shared by every project. You never
# edit the fleet to add a project.
#
# SCAFFOLD MODE — omit --code and the whole project is created from scratch:
# a git repo at ~/<name> (base commit) pushed to a new PRIVATE GitHub repo
# <owner>/<name>, a seeded+committed docs hub at ~/<name>-hub pushed to a
# private <owner>/<name>-hub, and QUEUE_KIND defaults to github
# (QUEUE_GITHUB_REPO = <owner>/<name>). Needs the gh CLI, authenticated. Pass
# --code to register an EXISTING repo instead (no scaffold).
#
#   fleet-init <name> [--code PATH] [--hub PATH] [--wt PATH] [--base REF]
#              [--agents claude,gemini]  (comma-separated packs, first = default)
#              [--ntfy TOPIC]            (worker attention notifications)
#              [--machine a,b]           (machines from the registry this project uses)
#              [--remote HOST]           (legacy single VM; = a machine named "remote")
#              [--queue linear|github|none]
#              [--linear-team T --linear-project-id ID --linear-project-name NAME]
#              [--github-repo owner/repo]
#              [--force]                 (overwrite an existing <name>.env)
set -euo pipefail
SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
TEMPLATES="$SELF_DIR/../templates"
ROOT="${FLEET_HOME:-$HOME/.config/fleet}"
PROJECTS="$ROOT/projects"

usage() {
  cat >&2 <<'EOF'
usage: fleet-init <name> [--code PATH] [options]
  --code PATH                   the project's code repo: must exist and have at
                                least one commit. OMIT it for SCAFFOLD MODE:
                                creates ~/<name> (base commit) + a private
                                GitHub repo <owner>/<name> pushed, a committed
                                hub at ~/<name>-hub pushed to a private
                                <owner>/<name>-hub, and queue defaults to github
  --hub PATH                    docs hub; a non-existent path gets seeded
                                (INDEX, AGENTS.md + CLAUDE.md bridge, skills).
                                In scaffold mode defaults to ~/<name>-hub
  --wt PATH                     worktree home (default: ~/wt-<name>)
  --base REF                    base ref for new workers (default: auto-detected
                                from the code repo: origin/HEAD -> origin/main
                                -> origin/master -> checked-out branch)
  --agents a,b,c                agent packs to enable, comma-separated
                                (first = default at launch; default: claude)
  --ntfy TOPIC                  ntfy.sh topic (or full URL) for worker
                                attention notifications
  --machine a,b                 machines this project runs on, comma-separated,
                                from the registry ($FLEET_HOME/machines/*.env);
                                "local" is implicit. Writes MACHINES=
  --remote HOST                 legacy single VM (writes REMOTE_HOST; treated as
                                a machine named "remote"). Prefer --machine
  --queue linear|github|none    agent-queue backend (default: none; scaffold
                                mode defaults to github on the new repo)
    --linear-team T --linear-project-id ID --linear-project-name NAME
    --github-repo owner/repo
  --force                       overwrite an existing <name>.env (for scripted,
                                idempotent setups like fleet-vm-setup)
Writes ~/.config/fleet/projects/<name>.env. Also callable as `fleet init ...`.
EOF
  exit 2
}
name="${1:-}"; shift || true
case "$name" in
  ""|-h|--help) usage ;;
  -*) echo "error: first argument must be the project name (got option '$name')" >&2; usage ;;
esac
case "$name" in *[!a-zA-Z0-9._-]*)
  echo "error: project name '$name' — use only letters, digits, '.', '_', '-'" >&2; exit 2 ;;
esac

code="" hub="" wt="" base="" agents="claude" ntfy="" remotehost="" machines_sel="" queue="none"
lt="" lpid="" lpname="" ghrepo="" force=0 queue_explicit=0
while [ $# -gt 0 ]; do
  case "$1" in
    --code) code="$2"; shift 2;;
    --hub) hub="$2"; shift 2;;
    --wt) wt="$2"; shift 2;;
    --base) base="$2"; shift 2;;
    --agents) agents="${2//,/ }"; shift 2;;
    --ntfy) ntfy="$2"; shift 2;;
    --machine|--machines) machines_sel="${2//,/ }"; shift 2;;
    --remote) remotehost="$2"; shift 2;;
    --queue) queue="$2"; queue_explicit=1; shift 2;;
    --linear-team) lt="$2"; shift 2;;
    --linear-project-id) lpid="$2"; shift 2;;
    --linear-project-name) lpname="$2"; shift 2;;
    --github-repo) ghrepo="$2"; shift 2;;
    --force) force=1; shift;;
    *) echo "error: unknown arg '$1'" >&2; exit 2;;
  esac
done

# The .env must hold absolute paths: cwd auto-detection (fleet-config.sh)
# compares them against $PWD. Expand a leading ~/ and absolutize. Anything the
# shell would normally expand but we cannot ('~user', a quoted '$VAR') is
# rejected loudly rather than silently mangled into a wrong path.
abspath() {
  local p="$1"
  case "$p" in
    "~")    p="$HOME" ;;
    "~/"*)  p="$HOME/${p#\~/}" ;;
    "~"*)   echo "error: ~user paths are not supported: $p" >&2; exit 2 ;;
    '$'*)   echo "error: shell variables are not expanded here: $p (pass a real path)" >&2; exit 2 ;;
  esac
  case "$p" in /*) ;; *) p="$PWD/$p" ;; esac
  printf '%s' "$p"
}

# Scaffold mode: no --code means "create the whole project from scratch". Set
# the from-scratch defaults now; the repo + hub are actually created below,
# after the cheap validations and the conf-exists check (so we never create a
# GitHub repo only to fail on an already-registered project).
scaffold=0
if [ -z "$code" ]; then
  scaffold=1
  code="$HOME/$name"
  [ -z "$hub" ] && hub="$HOME/$name-hub"
  [ "$queue_explicit" != 1 ] && queue="github"
fi
code="$(abspath "$code")"
wt="$(abspath "${wt:-$HOME/wt-$name}")"
[ -n "$hub" ] && hub="$(abspath "$hub")"
case "$queue" in linear|github|none) ;; *) echo "error: --queue must be linear|github|none" >&2; exit 2;; esac
PACKS_DIR="$SELF_DIR/../packs"
for a in $agents; do
  [ -f "$PACKS_DIR/$a/pack.sh" ] || { echo "error: unknown agent pack '$a' (no $PACKS_DIR/$a/pack.sh)" >&2; exit 2; }
done

mkdir -p "$PROJECTS"
conf="$PROJECTS/$name.env"
if [ -e "$conf" ] && [ "$force" != 1 ]; then
  echo "error: project '$name' already exists ($conf) — pass --force to overwrite" >&2
  exit 1
fi

# From-scratch creation: base commit in ~/<name>, pushed to a new private
# GitHub repo <owner>/<name>. Runs only after every cheap validation above, so
# a bad flag never leaves an orphan GitHub repo behind.
if [ "$scaffold" = 1 ]; then
  command -v gh >/dev/null 2>&1 || {
    echo "error: scaffold mode needs the gh CLI (https://cli.github.com), or pass --code PATH for an existing repo" >&2; exit 1; }
  gh auth status >/dev/null 2>&1 || { echo "error: gh is not authenticated — run 'gh auth login'" >&2; exit 1; }
  owner="$(gh api user -q .login)" || { echo "error: could not read your GitHub login via gh" >&2; exit 1; }
  [ -e "$code" ] && { echo "error: $code already exists — scaffold refuses to overwrite it (pass --code to register an existing repo)" >&2; exit 1; }
  if gh repo view "$owner/$name" >/dev/null 2>&1; then
    echo "error: GitHub repo $owner/$name already exists — pick another name or pass --code" >&2; exit 1
  fi
  ghrepo="${ghrepo:-$owner/$name}"
  # The hub is pushed too when we're about to seed a fresh one. Reserve its repo
  # name now so a collision fails before the code repo is created (no orphan).
  hubrepo=""
  if [ -n "$hub" ] && [ ! -e "$hub" ]; then
    hubrepo="$owner/$(basename "$hub")"
    if gh repo view "$hubrepo" >/dev/null 2>&1; then
      echo "error: GitHub repo $hubrepo (for the hub) already exists — pick another name or pass --hub" >&2; exit 1
    fi
  fi
  echo "[fleet-init] scaffolding code repo $code -> private github.com/$owner/$name ..."
  mkdir -p "$code"
  (
    set -e
    cd "$code"
    git init -q -b main
    printf '# %s\n\nScaffolded by fleet-init.\n' "$name" > README.md
    printf '.DS_Store\nnode_modules/\n__pycache__/\n*.log\n.env\n.venv/\n' > .gitignore
    git add -A
    git commit -q -m "chore: initial commit"
  ) || { echo "error: failed to create the base commit in $code (is your git user.name/user.email set?)" >&2; exit 1; }
  gh repo create "$owner/$name" --private --source="$code" --remote=origin --push \
    || { echo "error: 'gh repo create --push' failed for $owner/$name" >&2; exit 1; }
  [ -z "$base" ] && base="origin/main"
  echo "[fleet-init] pushed $owner/$name (base $base)."
fi

[ -d "$code" ] || { echo "error: code repo not found: $code" >&2; exit 1; }
code="$(cd "$code" && pwd)"
git -C "$code" rev-parse --verify --quiet HEAD >/dev/null || {
  echo "error: $code is not a git repo with at least one commit" >&2
  echo "  (from scratch: omit --code to scaffold, or git init + a first commit, then re-run)" >&2
  exit 1
}

# Base ref for new workers: --base wins, else scaffold already set it, else
# auto-detect from the code repo. origin/main hardcoded would break
# from-scratch repos (no remote) and master-default repos at the first `fleet w`.
if [ -z "$base" ]; then
  base="$(git -C "$code" symbolic-ref --quiet --short refs/remotes/origin/HEAD || true)"
  if [ -z "$base" ]; then
    if   git -C "$code" show-ref --verify --quiet refs/remotes/origin/main;   then base="origin/main"
    elif git -C "$code" show-ref --verify --quiet refs/remotes/origin/master; then base="origin/master"
    else base="$(git -C "$code" symbolic-ref --quiet --short HEAD || echo main)"
    fi
  fi
fi

# Seed the hub BEFORE writing the .env: if seeding fails, re-running is then a
# clean retry (no half-registered project). Context = AGENTS.md as the single
# source (Codex/opencode native, Gemini via context.fileName, Claude Code via
# the one-line CLAUDE.md bridge). Skills go to the cross-CLI standard dir
# .agents/skills/ (agentskills.io), with .claude/skills as a symlink for
# Claude Code, which does not read .agents/ yet.
if [ -n "$hub" ]; then
  if [ ! -e "$hub" ]; then
    # Seed into a temp sibling dir and move it into place only on success:
    # with direct writes, a failed/interrupted seed would leave a half-seeded
    # hub that the bare existence check below skips forever on retry.
    hub_parent="$(dirname "$hub")"; mkdir -p "$hub_parent"
    seed="$(mktemp -d "$hub_parent/.$(basename "$hub").seed-XXXXXX")"
    if (
      set -e
      cd "$seed" && git init -q -b main
      cp "$TEMPLATES/hub-INDEX.md"  INDEX.md
      cp "$TEMPLATES/hub-AGENTS.md" AGENTS.md
      printf '@AGENTS.md\n' > CLAUDE.md
      case " $agents " in *" gemini "*)
        mkdir -p .gemini
        printf '{\n  "context": { "fileName": ["AGENTS.md", "GEMINI.md", "CLAUDE.md"] }\n}\n' \
          > .gemini/settings.json
      ;; esac
      mkdir -p .agents/skills .claude
      for s in doc-nav process-agent-queue; do
        [ ! -d "$TEMPLATES/skills/$s" ] || cp -r "$TEMPLATES/skills/$s" .agents/skills/
      done
      ln -s ../.agents/skills .claude/skills
      # Scaffold leaves nothing half-done: commit the seed so the coordinator
      # opens on a clean tree instead of a pile of untracked files. Must be an
      # `if`, not `cond && {...}`: as the subshell's LAST command the latter
      # returns 1 when scaffold=0 (adopting an existing code repo), which would
      # fail the whole seed even though nothing went wrong.
      if [ "$scaffold" = 1 ]; then
        git add -A && git commit -q -m "chore: seed docs hub (fleet-init)"
      fi
    ); then
      mv "$seed" "$hub"
      if [ "$scaffold" = 1 ]; then
        echo "[fleet-init] seeded + committed hub $hub (INDEX, AGENTS + CLAUDE bridge, coordinator skills in .agents/skills)."
        # Push the hub too (private repo <owner>/<basename hub>); hubrepo was
        # reserved (name-availability checked) in the scaffold block above.
        if [ -n "$hubrepo" ]; then
          gh repo create "$hubrepo" --private --source="$hub" --remote=origin --push \
            || { echo "error: 'gh repo create --push' failed for the hub $hubrepo" >&2; exit 1; }
          echo "[fleet-init] pushed hub $hubrepo."
        fi
      else
        echo "[fleet-init] seeded hub $hub (INDEX, AGENTS + CLAUDE bridge, coordinator skills in .agents/skills). Edit them, then git commit."
      fi
    else
      rm -rf "$seed"
      echo "error: hub seeding failed — nothing was written to $hub; fix the cause and re-run" >&2
      exit 1
    fi
  else
    echo "[fleet-init] hub $hub exists — left as is."
  fi
fi

{
  echo "# $name project."
  echo "CODE_REPO=\"$code\""
  [ -n "$hub" ] && echo "HUB=\"$hub\""
  echo "WT_HOME=\"$wt\""
  echo "DEFAULT_BASE=\"$base\""
  echo "AGENTS=\"$agents\""
  [ -n "$ntfy" ] && echo "NTFY_TOPIC=\"$ntfy\""
  [ -n "$machines_sel" ] && echo "MACHINES=\"$machines_sel\""
  [ -n "$remotehost" ] && echo "REMOTE_HOST=\"$remotehost\""
  echo
  echo "QUEUE_KIND=\"$queue\""
  if [ "$queue" = linear ]; then
    echo "QUEUE_LINEAR_TEAM=\"$lt\""
    echo "QUEUE_LINEAR_PROJECT_ID=\"$lpid\""
    echo "QUEUE_LINEAR_PROJECT_NAME=\"$lpname\""
  elif [ "$queue" = github ]; then
    echo "QUEUE_GITHUB_REPO=\"${ghrepo:-}\""
  fi
  echo
  echo "# Resource guard rails (fleet refuses dispatch/w past a limit; 0 = off,"
  echo "# built-ins 6/2048/5120, per-machine override in machines/<name>.env)."
  echo "# MAX_WORKERS=6"
  echo "# MIN_FREE_MB=2048"
  echo "# MIN_FREE_DISK_MB=5120"
} > "$conf"
echo "[fleet-init] wrote $conf (workers base on $base)"
[ "$scaffold" = 1 ] && echo "[fleet-init] scaffold: code $code -> $ghrepo${hubrepo:+, hub $hub -> $hubrepo}, github queue on ${ghrepo}."

echo "[fleet-init] done. Coordinator: fleet --project $name    Worker: fleet --project $name w <task>"
echo "[fleet-init]       (from inside the repo/hub/worktree, --project is inferred)"
echo "[fleet-init] note: there is NO implicit default project — outside the repo/hub, always --project."
echo "[fleet-init] check posture:          fleet-assess --project $name"
if [ "$queue" = none ]; then
  echo "[fleet-init] queue = none: workers surface drift/findings to you directly (no tracker)."
fi
