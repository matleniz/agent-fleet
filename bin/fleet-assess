#!/usr/bin/env python3
"""fleet-assess — read the maturity of a docs hub and recommend a fleet posture.

The optimal way to run the fleet depends on how much *distilled shared context*
(C) already exists. When the hub is thin, building context means raw code reads
(expensive, per task) and there is no cheap C to reuse: keep the fleet narrow and
spend tokens MANUFACTURING context (write what you learn into the hub). When the
hub is rich, C is a cheap artifact (index -> one file -> grep): batch many small
tasks per warm worker, offload throwaway exploration to subagents, and scale wide.

This script scores observable signals in the hub and prints that recommendation.
It reads files only; it changes nothing. See docs/05-adaptive-posture.md for the
model behind the numbers.

Usage:
  fleet-assess --hub PATH [--code PATH]
  fleet-assess [--project NAME]     # resolves the project (--project / cwd; no default)
"""
import argparse
import os
import sys
import subprocess

SELF_DIR = os.path.dirname(os.path.realpath(__file__))

def load_conf(project=None, quiet=False):
    """Resolve + read the project config through bin/fleet-queue, so the shell
    resolver (fleet-config.sh) stays the single source of truth — a Python
    re-implementation of the resolution order had already drifted from it.
    Returns fleet-queue's KEY=VALUE lines as a dict, or None on failure (the
    resolver's own error, which lists known projects, goes to stderr unless
    quiet)."""
    cmd = [os.path.join(SELF_DIR, "fleet-queue")]
    if project:
        cmd += ["--project", project]
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
    if r.returncode != 0:
        if not quiet:
            sys.stderr.write(r.stderr)
        return None
    return dict(line.split("=", 1) for line in r.stdout.splitlines() if "=" in line)

def walk_md(root):
    """Return (n_files, total_bytes) of markdown docs under root, skipping git/screenshots."""
    n, b = 0, 0
    for dirpath, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in (".git", "node_modules", "SCREENSHOTS", ".claude", ".agents")]
        for f in files:
            if f.lower().endswith((".md", ".mermaid", ".mmd")):
                n += 1
                try:
                    b += os.path.getsize(os.path.join(dirpath, f))
                except OSError:
                    pass
    return n, b

def code_bytes(root):
    exts = (".py", ".js", ".ts", ".tsx", ".jsx", ".go", ".rs", ".java", ".rb", ".sql")
    b = 0
    for dirpath, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in (".git", "node_modules", ".venv", "venv", "dist", "build", "__pycache__")]
        for f in files:
            if f.endswith(exts):
                try:
                    b += os.path.getsize(os.path.join(dirpath, f))
                except OSError:
                    pass
    return b

def git_commits(root):
    try:
        out = subprocess.run(["git", "-C", root, "rev-list", "--count", "HEAD"],
                             capture_output=True, text=True, timeout=10)
        return int(out.stdout.strip() or 0)
    except Exception:
        return 0

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--hub")
    ap.add_argument("--code")
    ap.add_argument("--project", help="project name in ~/.config/fleet/projects/")
    args = ap.parse_args()
    conf = load_conf(args.project, quiet=bool(args.hub or args.code))
    if conf is None:
        if not (args.hub or args.code):
            sys.exit(2)  # fleet-queue's stderr already explained and listed projects
        conf = {}       # explicit --hub/--code: no resolved project needed
    hub = args.hub or conf.get("HUB")
    code = args.code or conf.get("CODE_REPO")
    if not hub or not os.path.isdir(hub):
        # A project with no hub is THIN by definition: nothing distilled to reuse.
        proj = args.project or conf.get("PROJECT") or "(this project)"
        print(f"project        : {proj}")
        print("docs hub       : NONE")
        print("\n>>> REGIME: THIN (no hub)\n")
        print("  There is no distilled shared context to reuse. Every task pays raw")
        print("  code reads. Run a narrow fleet (1-2 workers) and, if this project is")
        print("  worth it, create a hub: seed INDEX.md + AGENTS.md (fleet-init --hub")
        print("  does it, with the CLAUDE.md bridge and skills), and distill what")
        print("  you learn into it so future tasks get cheap context. See docs/05.")
        print("\n  You can also just work solo in the repo (one Claude, no fleet) and")
        print("  grow the hub as you go. The fleet is a scale-up, not a prerequisite.")
        return

    has_index = any(os.path.isfile(os.path.join(hub, n)) for n in ("INDEX.md", "index.md"))
    # Skills live in .agents/skills (the cross-CLI standard); .claude/skills is
    # kept for Claude Code (often a symlink to the former) — count the union.
    skill_names = set()
    for sd in (os.path.join(hub, ".agents", "skills"), os.path.join(hub, ".claude", "skills")):
        if os.path.isdir(sd):
            skill_names.update(os.listdir(sd))
    n_skills = len(skill_names)
    n_md, hub_bytes = walk_md(hub)
    commits = git_commits(hub)
    cov = None
    if code and os.path.isdir(code):
        cb = code_bytes(code)
        cov = (hub_bytes / cb) if cb else None

    # Score 0-6 -> regime. Signals: index router, doc volume, coverage, skills, history.
    score = 0
    score += 1 if has_index else 0
    score += 1 if n_md >= 8 else 0
    score += 1 if hub_bytes >= 40_000 else 0          # ~40 KB of distilled doc
    score += 1 if (cov is not None and cov >= 0.02) else 0  # doc >= 2% of code size
    score += 1 if n_skills >= 3 else 0
    score += 1 if commits >= 20 else 0

    if score <= 1:
        regime = "THIN"
    elif score <= 4:
        regime = "GROWING"
    else:
        regime = "MATURE"

    postures = {
        "THIN": [
            "Fleet width: NARROW (1-2 workers). Parallelism has little cheap C to",
            "  amortize against and high rework risk (no shared doc keeps workers aligned).",
            "Primary spend: MANUFACTURE context. Every expensive read a worker does",
            "  should be distilled into the hub before the worker is reset, so it is",
            "  paid once, forever. The coordinator's early job is to build the map.",
            "Warm workers: yes, keep one warm across tasks in the same subsystem;",
            "  write a hub note at the end of the batch so the next worker inherits it.",
            "Subagent offload: LOW value here (the exploration IS the deliverable;",
            "  capture it into the hub, do not discard it in a subagent).",
        ],
        "GROWING": [
            "Fleet width: MEDIUM. Route workers by ZONE maturity, not evenly.",
            "Documented zones -> exploit: batch small tasks on a warm worker, offload",
            "  throwaway exploration to subagents with a compact brief.",
            "Undocumented zones -> treat as THIN: distill what you learn into the hub.",
            "The tipping point is now per-zone. Run fleet-assess again as coverage grows.",
            "Keep filling the index: an entry per subsystem is the cheapest future token win.",
        ],
        "MATURE": [
            "Fleet width: WIDE across INDEPENDENT workstreams (not inside one change).",
            "Warm workers: batch many small tasks per worker; load C once (index -> one",
            "  file -> grep), reuse it from cache across the batch. Reset at the next",
            "  context boundary, not per task.",
            "Subagent offload: HIGH value. Throwaway exploration (read 15 files to change",
            "  3 lines) goes to a subagent that returns only the distillate, so the warm",
            "  worker accumulates results, not raw digs.",
            "Primary spend: EXPLOIT cheap C. Watch transcript accumulation, not C rebuild.",
        ],
    }

    print(f"hub            : {hub}")
    print(f"index router   : {'yes' if has_index else 'NO (add INDEX.md first)'}")
    print(f"doc files      : {n_md}")
    print(f"distilled size : {hub_bytes/1000:.0f} KB")
    print(f"skills in hub  : {n_skills}")
    print(f"hub commits    : {commits}")
    if cov is not None:
        print(f"doc/code ratio : {cov*100:.1f}% (coverage proxy)")
    print(f"maturity score : {score}/6")
    print(f"\n>>> REGIME: {regime}\n")
    for line in postures[regime]:
        print("  " + line)
    print("\n(Model: docs/05-adaptive-posture.md. Re-run as the hub grows.)")

if __name__ == "__main__":
    main()
