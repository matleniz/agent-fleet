# Copy to deploy/.env (gitignored) and fill in. Do NOT commit the real file.

# Fine-grained GitHub token, scoped to the repos below, with
# Contents: Read and write (clone + workers push branches / open PRs).
GH_TOKEN=github_pat_xxx

# The project this container runs. Single-project (this block) is the default;
# for several projects set PROJECTS= at the bottom instead.
PROJECT_NAME=myproj

# Optional: names, so several containers can run on ONE host (default: fleet).
# On distinct VMs leave them unset. A machine-registry entry on your laptop
# ($FLEET_HOME/machines/<name>.env) points at one container via MACHINE_CONTAINER
# / MACHINE_TMUX matching these.
# FLEET_CONTAINER=fleet     # docker container name
# FLEET_TMUX=fleet          # tmux session name inside it
# FLEET_VOLUME=fleet-home   # persistent volume name
CODE_REPO_URL=https://github.com/<org>/<code-repo>.git   # needs >=1 commit
# Optional docs hub (omit the line for a project with no hub):
HUB_REPO_URL=https://github.com/<org>/<hub-repo>.git

# Agent packs to enable (space-separated, first = default at launch).
# They must be baked in the image: build with --build-arg PACKS="claude opencode".
AGENTS=claude

# Optional: ntfy.sh topic (or full URL) for worker attention notifications.
# NTFY_TOPIC=my-secret-fleet-topic

# Agent queue backend: linear | github | none.
QUEUE_KIND=none
# QUEUE_KIND=linear:
# QUEUE_LINEAR_TEAM=TEAM
# QUEUE_LINEAR_PROJECT_ID=<uuid>
# QUEUE_LINEAR_PROJECT_NAME=Agent Queue
# LINEAR_API_KEY=lin_api_xxx        # lets skills use the Linear API without an MCP
# QUEUE_KIND=github:
# QUEUE_GITHUB_REPO=owner/repo

# ---- Multiple projects in one container (optional) ----
# Set PROJECTS instead of the single-project block above, and give each project
# its vars under its UPPERCASED namespace. AGENTS / QUEUE_KIND / NTFY_TOPIC above
# act as per-project defaults. fleet-vm-setup provisions all of them (idempotent).
# You can also add one later without a rebuild:
#   docker exec -it fleet fleet-vm-setup --add-project <name> --repo <url> [--hub <url>] ...
# PROJECTS="alpha beta"
# ALPHA_CODE_REPO_URL=https://github.com/<org>/alpha.git
# BETA_CODE_REPO_URL=https://github.com/<org>/beta.git
# BETA_HUB_REPO_URL=https://github.com/<org>/beta-hub.git
# BETA_AGENTS="claude"
# BETA_QUEUE_KIND=linear
# BETA_QUEUE_LINEAR_TEAM=BETA
