# agent-fleet cross-project defaults.
# Copy to ~/.config/fleet/default.env and edit. Sourced by every project BEFORE
# its own .env, so a project always wins over what you set here. There is
# deliberately NO default project — this file only holds shared defaults, never a
# project selection.

# Machines common to EVERY project, space-separated. Each must have a registry
# entry ~/.config/fleet/machines/<name>.env (template: machine.env). A project
# adds its own with MACHINES="local ..." in its .env; those merge with these.
# MACHINES_DEFAULT="vm-gpu"

# Resource guard rails — global defaults for the per-machine worker/RAM/disk
# limits fleet enforces before launching a worker (fleet refuses dispatch/w past
# a limit; --force or FLEET_NO_GUARD=1 bypasses). Precedence, most-specific wins:
#   machines/<name>.env (MACHINE_MAX_WORKERS/...) > project .env > this file >
#   built-ins (6 workers / 2048MB RAM / 5120MB disk). 0 = that check off.
# See docs/07-machine-and-solo.md.
# MAX_WORKERS=6                # live workers per machine
# MIN_FREE_MB=2048            # refuse below this much free RAM (MB)
# MIN_FREE_DISK_MB=5120       # refuse below this much free disk (MB) on WT_HOME
