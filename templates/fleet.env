# agent-fleet project config.
# Copy to ~/.config/fleet/projects/<project-name>.env and edit.
# Read by fleet, new-worker, and fleet-assess. The active project is resolved by
# --project <name> / $FLEET_PROJECT / your current directory — and NOTHING else:
# there is no implicit default project (a silent fallback breeds confusion).

# Absolute path to the single clone of this project's code repo. (required)
CODE_REPO="$HOME/your-code-repo"

# Absolute path to this project's docs hub, read-only from workers.
# Leave unset for a project with no hub yet (it is THIN by definition; workers
# get a plain worktree with no barrier). (optional)
HUB="$HOME/your-hub"

# Where worktrees are created for this project, one dir per worker. (required)
WT_HOME="$HOME/wt-your-project"

# Optional: a shared light tooling venv (linters), pointed at by editors.
# TOOLS_VENV="$HOME/.venvs/tools"

# Optional: base ref for new worker branches. fleet-init auto-detects it from
# the code repo (origin/HEAD -> origin/main -> origin/master -> checked-out
# branch); when unset entirely, new-worker falls back to origin/main.
# DEFAULT_BASE="origin/main"

# Agent packs enabled for this project, space-separated (first = the default
# at launch; pick another per session with `fleet -a <pack>`). Each enabled
# pack sets up every worktree, so any enabled agent can open any worktree.
# Default if unset: claude.
AGENTS="claude"

# Lean worker MCP profile (optional): a space-separated allowlist of MCP server
# names a worker in this project should load — fewer servers = fewer tool schemas
# injected per session = fewer tokens (see docs/06). Applied to each worktree by
# pack_worker_setup. Unset/empty = inherit whatever the machine has (no change);
# "none" = no MCP servers. Honored by gemini + opencode (full) and claude (gates
# the project .mcp.json only; user-scope servers still load, see docs/06). cursor,
# copilot and antigravity can't scope MCP per worktree, so they ignore it.
# WORKER_MCP="linear"

# Machines this project runs on, space-separated (default: "local"). They are a
# global pool defined in ~/.config/fleet/machines/<name>.env (template:
# templates/machine.env, or `fleet machines add`); "local" is this box and needs
# no file. `fleet --machine <name> ...` runs a session there; `fleet r` is
# shorthand for the first non-local machine. See `fleet machines`.
# MACHINES="local vm-gpu"
#
# Machines common to EVERY project can go in MACHINES_DEFAULT in
# ~/.config/fleet/default.env instead of being repeated here.
#
# Legacy single-VM shorthand (still works, synthesized as a machine named
# "remote"): prefer MACHINES + a registry entry for anything new.
# REMOTE_HOST="my-vm"          # ssh host/alias; unset = no remote
# REMOTE_CONTAINER="fleet"     # docker container name (default: fleet)
# REMOTE_TMUX="fleet"          # tmux session name (default: fleet)
# REMOTE_ENGINE_DIR / REMOTE_PROJECT when paths/names differ on the VM.

# Resource guard rails: fleet refuses `dispatch`/`w` when the target machine is
# at its worker/RAM/disk limit (fail-fast; --force or FLEET_NO_GUARD=1 bypasses).
# Set these here for a project-wide default, in default.env for a global one, or
# per machine (MACHINE_MAX_WORKERS/... in machines/<name>.env). 0 = check off;
# most-specific wins. Built-in defaults: 6 workers / 2048MB RAM / 5120MB disk.
# See docs/07-machine-and-solo.md.
# MAX_WORKERS=6                # live workers per machine
# MIN_FREE_MB=2048            # refuse below this much free RAM (MB)
# MIN_FREE_DISK_MB=5120       # refuse below this much free disk (MB) on WT_HOME
# The guard only gates at launch. On a small box also cap each node worker's V8
# heap so a leaking CLI is OOM-killed cleanly instead of freezing the host (0 =
# off; size above a legit build, it is inherited by the worker's own node):
# WORKER_NODE_MAX_MB=2048     # e.g. 2048 on an ~8 GiB box; built-in default 0

# Optional: push notifications when a worker needs attention (waiting on a
# permission, finished its turn). A bare word = a topic on ntfy.sh (pick an
# unguessable one and subscribe from the ntfy mobile app); a full URL = your
# own ntfy server. Wired into each worker by the packs that support hooks
# (claude today). Unset = no notifications.
# NTFY_TOPIC="my-secret-fleet-topic"

# Agent queue backend for proposals/findings. The generic workflow skills read
# these (via `fleet-queue`) so they never hardcode one project's tracker.
QUEUE_KIND="none"            # linear | github | none
# QUEUE_KIND=linear:
# QUEUE_LINEAR_TEAM="TEAM"
# QUEUE_LINEAR_PROJECT_ID="<uuid>"
# QUEUE_LINEAR_PROJECT_NAME="Agent Queue"
# QUEUE_KIND=github:
# QUEUE_GITHUB_REPO="owner/repo"
