# agent-fleet machine registry entry.
# Copy to ~/.config/fleet/machines/<machine-name>.env and edit (or use
# `fleet machines add <name> <ssh-host>`). A machine is a place a session runs:
# a VM running the deploy/ container. The local box is the implicit "local"
# machine and needs no file here.
#
# Machines are a GLOBAL POOL: any project can use any machine. A project picks
# which ones with MACHINES="local <name> ..." in its .env (see fleet.env), or
# put machines common to every project in MACHINES_DEFAULT in
# ~/.config/fleet/default.env. Inspect with `fleet machines`.

# ssh host or alias for this machine (required). "local" means this box.
MACHINE_HOST="my-vm"

# Docker container running the fleet image on that host (default: fleet).
MACHINE_CONTAINER="fleet"

# tmux session name inside the container (default: fleet).
MACHINE_TMUX="fleet"

# Where the engine repo lives on the host, for `fleet sync-remote`
# (default: agent-fleet, i.e. ~/agent-fleet).
MACHINE_ENGINE_DIR="agent-fleet"

# Optional: the project's name on that box, if it differs from the local one
# (fleet passes --project this when opening sessions there).
# MACHINE_PROJECT="myproj"

# Resource guard rails for THIS machine (fleet refuses a new worker past a
# limit; 0 = that check off). Override the global defaults in default.env, which
# in turn override the built-ins (6 / 2048 / 5120). Size them to the box: a big
# VM tolerates more workers than a laptop. See docs/07-machine-and-solo.md.
# MACHINE_MAX_WORKERS=10        # live workers allowed on this machine
# MACHINE_MIN_FREE_MB=4096      # refuse below this much free RAM (MB)
# MACHINE_MIN_FREE_DISK_MB=10240  # refuse below this much free disk (MB)
